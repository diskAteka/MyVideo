          "likes": {
            "type": "integer",
            "format": "int32"
          },
          "dislikes": {
            "type": "integer",
            "format": "int32"
          },
          "isLiked": {
            "type": "boolean"
          },
          "isDisLiked": {
            "type": "boolean"
          },
          "comments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CommentResponse"
