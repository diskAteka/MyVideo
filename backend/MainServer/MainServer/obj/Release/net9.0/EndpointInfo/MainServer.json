            "nullable": true
          },
          "videoUrl": {
            "type": "string",
            "nullable": true
          },
          "posterUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "VideoListItemResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
