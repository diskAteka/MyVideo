          "poster": {
            "type": "string",
            "nullable": true
          },
          "dateUpload": {
            "type": "string",
            "format": "date-time"
          },
          "authorName": {
            "type": "string",
            "nullable": true
          },
          "isVerified": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "VideoDetailsResponse": {
        "type": "object",
        "properties": {
